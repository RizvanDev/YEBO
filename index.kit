			<section class="mail">
				<div class="container">
					<div class="mail__logo">
						<img src="images/icons/header__logo.png" alt="">
						<h3>Stay on the saddle!</h3>
					</div>
					<form action="#" class="form__mail">
						<input placeholder="enter your email..." type="email" autocomplete="email" required>
						<button type="submit" class="mail__btn">
							<span>go!</span>
						</button>
					</form>
				</div>
			</section>
