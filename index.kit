				<a id="shop"></a>
				<div class="shop">
					<div class="shop__row">
						<div class="shop__left">
							<div class="left__top">
								<a href="" class="hover">
									<span class="logo">
										<img src="images/icons/shope-bike.png" alt="">
										<span>show now</span>
									</span>
									<img src="images/shop01.jpg" alt=""></a>
								<a href="" class="hover">
									<span class="logo">
										<img src="images/icons/shope-bike.png" alt="">
										<span>show now</span>
									</span>
									<img src="images/shop02.jpg" alt=""></a>
							</div>
							<div class="left__bottom hover">
